{
  "description": "Yet another state management in React",
  "license": "MIT",
  "name": "@dvashim/store",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.4.0",
  "author": {
    "email": "aleksei@dvashim.dev",
    "name": "Aleksei Reznichenko"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@dvashim/biome-config": "^1.3.2",
    "@dvashim/typescript-config": "^1.1.11",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "state-manager",
    "useSyncExternalStore",
    "store",
    "minimal",
    "lightweight",
    "typescript"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dvashim/store.git"
  },
  "scripts": {
    "build": "tsc --project tsconfig.dev.json",
    "changeset": "changeset",
    "check": "pnpm run \"/^check:.*/\"",
    "check:biome": "biome check",
    "check:ts": "tsc --noemit",
    "ci": "pnpm check && pnpm test",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "pnpm build --watch"
  }
}
