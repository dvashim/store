{
  "name": "@dvashim/store",
  "version": "1.5.3",
  "description": "Yet another state management in React",
  "keywords": [
    "lightweight",
    "minimal",
    "react",
    "state-manager",
    "store",
    "typescript",
    "useSyncExternalStore"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dvashim/store.git"
  },
  "license": "MIT",
  "author": {
    "name": "Aleksei Reznichenko",
    "email": "aleksei@dvashim.dev"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.dev.json",
    "changeset": "changeset",
    "check": "pnpm run \"/^check:.*/\"",
    "check:biome": "biome check",
    "check:ts": "tsc --noemit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "pnpm build --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@dvashim/biome-config": "^1.5.1",
    "@dvashim/typescript-config": "^2.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
