{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "extends": ["@dvashim/biome-config/react-balanced"],
  "assist": {
    "actions": {
      "source": {
        "useSortedKeys": {
          "level": "on",
          "options": {
            "groupByNesting": true
          }
        }
      }
    }
  },
  "linter": {
    "rules": {
      "nursery": {
        "noIncrementDecrement": "off"
      },
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["error"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["package.json"],
      "assist": {
        "actions": {
          "source": {
            "useSortedKeys": "off"
          }
        }
      },
      "json": {
        "formatter": {
          "expand": "always"
        }
      }
    },
    {
      "includes": ["vitest.config.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off"
          }
        }
      }
    },
    {
      "includes": ["tests/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off"
          },
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          },
          "style": {
            "noMagicNumbers": "off",
            "useFilenamingConvention": "off"
          },
          "suspicious": {
            "noEmptyBlock": "off",
            "noEmptyBlockStatements": "off"
          }
        }
      }
    }
  ]
}
